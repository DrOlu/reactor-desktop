{
	"$schema": "https://raw.githubusercontent.com/nicegui/nicegui/refs/heads/main/nicegui/static/tauri_v2_schema.json",
	"productName": "Pi Desktop",
	"identifier": "com.pi.desktop",
	"version": "0.1.0",
	"build": {
		"beforeDevCommand": "npx vite --port 1420",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build:frontend",
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "Pi Desktop",
				"width": 1100,
				"height": 750,
				"minWidth": 600,
				"minHeight": 400,
				"decorations": false,
				"transparent": false,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"shell": {
			"open": true
		}
	}
}
